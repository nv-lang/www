---
// BaseLayout — базовый каркас страницы.
// Ф.1: минимальный скелет. В Ф.2 сюда подключаются Head/Header/Footer
// и переносится укреплённый <head> из плана www-01 (CSP, og, hreflang, JSON-LD).
interface Props {
  title: string;
  description?: string;
  lang?: string;
}
const { title, description = '', lang = 'ru' } = Astro.props;
---

<!DOCTYPE html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
  </head>
  <body>
    <slot />
  </body>
</html>
